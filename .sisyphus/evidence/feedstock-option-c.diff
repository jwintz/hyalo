diff --git a/pixi.toml b/pixi.toml
index 024d226..dea66bb 100644
--- a/pixi.toml
+++ b/pixi.toml
@@ -6,47 +6,36 @@ channels = ["https://repo.prefix.dev/jwintz", "conda-forge"]
 platforms = ["osx-arm64"]
 
 [dependencies]
-# Build tools
 autoconf = "*"
 automake = "*"
 make = "*"
 pkg-config = "*"
 texinfo = "*"
-
-# Required libraries
 gnutls = "*"
 libxml2 = "*"
 ncurses = "*"
 zlib = "*"
-
-# Image libraries
 giflib = "*"
 libjpeg-turbo = "*"
 libpng = "*"
 libtiff = "*"
 lcms2 = "*"
-
-# SVG support (requires cairo and glib stack)
 librsvg = "*"
 cairo = "*"
 glib = "*"
 gdk-pixbuf = "*"
 pango = "*"
 expat = "*"
-
-# JSON support
 jansson = "*"
-
-# Tree-sitter support (incremental parsing for syntax highlighting, indentation)
 libtree-sitter = ">=0.20.10"
-
-# Native compilation (Emacs Lisp to native machine code via libgccjit)
 libgccjit = ">=15.2.0"
 
 [tasks]
-# Apply patches to emacs submodule (only runs if .patched is missing)
-patch = { cwd = "emacs", cmd = """
-git checkout . && \
+mac_prep = { cmd = "rsync -a --delete --exclude=.git emacs/ emacs-build-macos/", description = "Populate emacs-build-macos/ from pristine emacs/" }
+
+ios_sim_prep = { cmd = "rsync -a --delete --exclude=.git emacs/ emacs-build-ios-sim/", description = "Populate emacs-build-ios-sim/ from pristine emacs/" }
+
+mac_patch = { cwd = "emacs-build-macos", cmd = """
 patch -p1 < ../patches/system-appearance.patch && \
 patch -p1 < ../patches/frame-transparency.patch && \
 patch -p1 < ../patches/unidata-gen-incf.patch && \
@@ -54,17 +43,14 @@ patch -p1 < ../patches/loaddefs-gen-fix.patch && \
 patch -p1 < ../patches/derived-fix.patch && \
 cp ../icons/Emacs.icns nextstep/Cocoa/Emacs.base/Contents/Resources/Emacs.icns && \
 touch .patched && \
-echo 'Patches applied successfully.'
-""", outputs = [".patched"], description = "Apply patches to emacs submodule" }
+echo 'Patches applied successfully to emacs-build-macos/'
+""", depends-on = ["mac_prep"], outputs = ["emacs-build-macos/.patched"], description = "Apply patches to emacs-build-macos/" }
 
-# Revert patches by restoring emacs submodule to clean state
-unpatch = { cwd = "emacs", cmd = "git checkout . && rm -f .patched", description = "Revert all patches in emacs submodule" }
+mac_unpatch = { cmd = "rm -rf emacs-build-macos/ && mkdir -p emacs-build-macos/", description = "Clean emacs-build-macos/ for fresh build" }
 
-# Generate configure script from configure.ac
-autogen = { cwd = "emacs", cmd = "./autogen.sh", depends-on = ["patch"], inputs = ["configure.ac"], outputs = ["configure"], description = "Generate configure script" }
+mac_autogen = { cwd = "emacs-build-macos", cmd = "./autogen.sh", depends-on = ["mac_patch"], inputs = ["emacs-build-macos/configure.ac"], outputs = ["emacs-build-macos/configure"], description = "Generate configure script for macOS" }
 
-# Configure for macOS with NS support
-configure = { cwd = "emacs", cmd = """
+mac_configure = { cwd = "emacs-build-macos", cmd = """
 ./configure \
   --with-ns \
   --with-gnutls \
@@ -83,31 +69,65 @@ configure = { cwd = "emacs", cmd = """
   PKG_CONFIG_PATH=\"$CONDA_PREFIX/lib/pkgconfig:$PKG_CONFIG_PATH\" \
   RSVG_CFLAGS=\"-I$CONDA_PREFIX/include/librsvg-2.0 -I$CONDA_PREFIX/include/gdk-pixbuf-2.0 -I$CONDA_PREFIX/include/cairo -I$CONDA_PREFIX/include/glib-2.0 -I$CONDA_PREFIX/lib/glib-2.0/include\" \
   RSVG_LIBS=\"-L$CONDA_PREFIX/lib -lrsvg-2 -lm -lgdk_pixbuf-2.0 -lcairo -lgio-2.0 -lgobject-2.0 -lglib-2.0\"
-""", depends-on = ["autogen"], inputs = ["configure"], outputs = ["config.status"], description = "Configure Emacs with NS support" }
+""", depends-on = ["mac_autogen"], inputs = ["emacs-build-macos/configure"], outputs = ["emacs-build-macos/config.status"], description = "Configure Emacs for macOS with NS support" }
+
+mac_build = { cwd = "emacs-build-macos", cmd = "make -j$(sysctl -n hw.ncpu)", depends-on = ["mac_configure"], description = "Build Emacs for macOS" }
+
+mac_autoloads = { cwd = "emacs-build-macos/lisp", cmd = "make autoloads", depends-on = ["mac_configure"], description = "Update loaddefs.el for macOS" }
+
+mac_bootstrap = { cwd = "emacs-build-macos", cmd = "make bootstrap -j$(sysctl -n hw.ncpu)", depends-on = ["mac_configure"], description = "Bootstrap Emacs for macOS" }
+
+mac_install = { cwd = "emacs-build-macos", cmd = "make install && codesign --force --deep --sign - ./nextstep/Emacs.app", depends-on = ["mac_build"], outputs = ["emacs-build-macos/nextstep/Emacs.app/Contents/MacOS/Emacs"], description = "Install Emacs.app for macOS and sign" }
+
+mac_run = { cwd = "emacs-build-macos", cmd = "./nextstep/Emacs.app/Contents/MacOS/Emacs", depends-on = ["mac_install"], description = "Run Emacs.app for macOS" }
+
+mac_clean = { cwd = "emacs-build-macos", cmd = "make clean", description = "Clean macOS build artifacts" }
+
+mac_distclean = { cwd = "emacs-build-macos", cmd = "make distclean 2>/dev/null || true && rm -f .patched lib/gmp.h", description = "Deep clean macOS build" }
+
+mac_check = { cwd = "emacs-build-macos", cmd = "make check", depends-on = ["mac_build"], description = "Run Emacs test suite for macOS" }
+
+ios_sim_patch = { cwd = "emacs-build-ios-sim", cmd = """
+patch -p1 < ../patches/system-appearance.patch && \
+patch -p1 < ../patches/frame-transparency.patch && \
+patch -p1 < ../patches/unidata-gen-incf.patch && \
+patch -p1 < ../patches/loaddefs-gen-fix.patch && \
+patch -p1 < ../patches/derived-fix.patch && \
+touch .patched && \
+echo 'Patches applied successfully to emacs-build-ios-sim/'
+""", depends-on = ["ios_sim_prep"], outputs = ["emacs-build-ios-sim/.patched"], description = "Apply patches to emacs-build-ios-sim/" }
+
+ios_sim_unpatch = { cmd = "rm -rf emacs-build-ios-sim/ && mkdir -p emacs-build-ios-sim/", description = "Clean emacs-build-ios-sim/ for fresh build" }
+
+ios_sim_autogen = { cwd = "emacs-build-ios-sim", cmd = "./autogen.sh", depends-on = ["ios_sim_patch"], inputs = ["emacs-build-ios-sim/configure.ac"], outputs = ["emacs-build-ios-sim/configure"], description = "Generate configure script for iOS Simulator" }
+
+ios_sim_configure = { cwd = "emacs-build-ios-sim", cmd = "echo 'iOS Simulator configure not yet implemented'", depends-on = ["ios_sim_autogen"], description = "Configure Emacs for iOS Simulator (stub)" }
+
+ios_sim_build = { cwd = "emacs-build-ios-sim", cmd = "echo 'iOS Simulator build not yet implemented'", depends-on = ["ios_sim_configure"], description = "Build Emacs for iOS Simulator (stub)" }
+
+patch = { depends-on = ["mac_patch"], description = "Apply patches (delegates to mac_patch)" }
+
+unpatch = { depends-on = ["mac_unpatch"], description = "Clean build directory (delegates to mac_unpatch)" }
+
+autogen = { depends-on = ["mac_autogen"], description = "Generate configure script (delegates to mac_autogen)" }
+
+configure = { depends-on = ["mac_configure"], description = "Configure Emacs (delegates to mac_configure)" }
 
-# Build Emacs
-build = { cwd = "emacs", cmd = "make -j$(sysctl -n hw.ncpu)", depends-on = ["configure"], description = "Build Emacs" }
+build = { depends-on = ["mac_build"], description = "Build Emacs (delegates to mac_build)" }
 
-# Update loaddefs.el (useful if build fails with void function errors)
-autoloads = { cwd = "emacs/lisp", cmd = "make autoloads", depends-on = ["configure"], description = "Update loaddefs.el" }
+autoloads = { depends-on = ["mac_autoloads"], description = "Update loaddefs.el (delegates to mac_autoloads)" }
 
-# Bootstrap Emacs (full rebuild, recommended if build fails)
-bootstrap = { cwd = "emacs", cmd = "make bootstrap -j$(sysctl -n hw.ncpu)", depends-on = ["configure"], description = "Bootstrap Emacs" }
+bootstrap = { depends-on = ["mac_bootstrap"], description = "Bootstrap Emacs (delegates to mac_bootstrap)" }
 
-# Install into nextstep directory
-install = { cwd = "emacs", cmd = "make install && codesign --force --deep --sign - ./nextstep/Emacs.app", depends-on = ["build"], outputs = ["nextstep/Emacs.app/Contents/MacOS/Emacs"], description = "Install Emacs.app and sign" }
+install = { depends-on = ["mac_install"], description = "Install Emacs.app (delegates to mac_install)" }
 
-# Run the built Emacs
-run = { cwd = "emacs", cmd = "./nextstep/Emacs.app/Contents/MacOS/Emacs", depends-on = ["install"], description = "Run Emacs.app" }
+run = { depends-on = ["mac_run"], description = "Run Emacs.app (delegates to mac_run)" }
 
-# Clean build artifacts
-clean = { cwd = "emacs", cmd = "make clean", description = "Clean build artifacts" }
+clean = { depends-on = ["mac_clean"], description = "Clean build artifacts (delegates to mac_clean)" }
 
-# Deep clean including configure output and patches
-distclean = { cwd = "emacs", cmd = "make distclean 2>/dev/null || true && git checkout . && rm -f .patched lib/gmp.h", description = "Deep clean" }
+distclean = { depends-on = ["mac_distclean"], description = "Deep clean (delegates to mac_distclean)" }
 
-# Run the test suite
-check = { cwd = "emacs", cmd = "make check", depends-on = ["build"], description = "Run Emacs test suite" }
+check = { depends-on = ["mac_check"], description = "Run test suite (delegates to mac_check)" }
 
 [environments]
 default = { features = [], solve-group = "default" }
